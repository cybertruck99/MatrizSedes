APP_NAME="Matriz SEDES"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/La_Paz
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_BO

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=matriz_sedes
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=public
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Recomendado para generar reportes PDF cuando soffice no esta en el PATH.
# Linux: SOFFICE_PATH=/usr/bin/soffice
# Windows: SOFFICE_PATH="C:/Program Files/LibreOffice/program/soffice.exe"
SOFFICE_PATH=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="sistema@sedespotosi.gob.bo"
MAIL_FROM_NAME="${APP_NAME}"
